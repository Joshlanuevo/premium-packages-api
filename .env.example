# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Firebase (same project(s) as core POTB, since Firestore stays shared).
# Which set gets used is picked automatically based on NODE_ENV:
#   NODE_ENV=production -> PROD_* vars
#   anything else       -> DEV_* vars
# So both sets can live in this same file without colliding.

DEV_FIREBASE_PROJECT_ID=
DEV_FIREBASE_CLIENT_EMAIL=
# Paste the private key with \n literal newlines, or load from a mounted file instead
DEV_FIREBASE_PRIVATE_KEY=

PROD_FIREBASE_PROJECT_ID=
PROD_FIREBASE_CLIENT_EMAIL=
PROD_FIREBASE_PRIVATE_KEY=

# Auth: core POTB issues the tokens this service verifies.
# If POTB uses Firebase Auth custom tokens, firebase-admin verifyIdToken() covers this
# with no extra config. If POTB uses its own JWT (not Firebase Auth), replace the
# verification strategy in src/middleware/auth.ts and set a shared secret/JWKS URL here instead.
# CORE_POTB_JWT_SECRET=
# CORE_POTB_JWKS_URL=

LAKBAYHUB_AUTH_API_URL_DEV=
LAKBAYHUB_AUTH_API_URL_PROD=
